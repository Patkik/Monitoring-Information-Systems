# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=MentoringSystemComSoc
MONGODB_URI_FALLBACK=mongodb://username:password@host1:27017,host2:27017,host3:27017/?authSource=admin&replicaSet=your-replica-set&tls=true&retryWrites=true&w=majority

# JWT & Security
JWT_SECRET=your-secure-secret-key-minimum-32-characters-required
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Client URLs (comma-separated for CORS)
# Development: http://localhost:5173,http://localhost:5174,http://localhost:3000
# Production (example): https://monitoring-information-systems-beta.vercel.app
CLIENT_URLS=http://localhost:5173,http://localhost:5174,http://localhost:3000
CLIENT_URL=http://localhost:5173

# Server Configuration
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
SERVER_URL=http://localhost:4000

# OAuth Credentials (if using)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Pusher Configuration (Real-time notifications)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap1

# File Upload (Cloudinary Configuration)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@mentoring-system.com
SMTP_FROM_NAME=Mentoring System

# Feature Flags
FEATURE_FEEDBACK_ENABLED=true
FEATURE_CERTIFICATES_ENABLED=true
FEATURE_CHAT_ENABLED=true

# Logging
LOG_LEVEL=debug

# Session Configuration
SESSION_SECRET=your_session_secret_key_here

# Admin Configuration
ADMIN_EMAIL=admin@mentoring-system.com
ADMIN_PASSWORD=admin123!

# MongoDB Connection Retry Configuration (optional)
MONGODB_CONNECT_RETRIES=5
MONGODB_CONNECT_BACKOFF_MS=1000
