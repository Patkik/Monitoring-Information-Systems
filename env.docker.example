# Copy this file to .env.docker before running docker compose.
# Example:
#   cp env.docker.example .env.docker

# Container port mapping
FRONTEND_PORT=80
BACKEND_PORT=4000

# Backend runtime
MONGO_DB_NAME=mentoring_system
JWT_SECRET=change-this-secret-before-production
CLIENT_URLS=http://localhost,http://127.0.0.1
SERVER_URL=http://localhost
MONGODB_CONNECT_RETRIES=10
MONGODB_CONNECT_BACKOFF_MS=2000

# Frontend build-time config
VITE_API_URL=/api
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=
